      "0": {
        "type": "markdown",
        "content": "# 🔒 Security Overview"
      },
      "1": {
        "title": "Validation Policies Status",
        "type": "data",
        "query": "timeseries { sum(kyverno_policy_rule_info_total), value.A = avg(kyverno_policy_rule_info_total, scalar: true) }, by: { policy_name, status_ready }\n| fields policy_name, status_ready",
        "visualization": "table",
        "visualizationSettings": {
          "autoSelectVisualization": false,
          "coloring": {
            "colorRules": [
              {
                "colorMode": "custom-color",
                "comparator": "=",
                "customColor": {
                  "Default": "var(--dt-colors-charts-status-ideal-default, #2f6862)"
                },
                "field": "status_ready",
                "metadata": {
                  "applyTo": "cell",
                  "fields": [
                    "status_ready"
                  ]
                },
                "value": "true"
              },
              {
                "colorMode": "custom-color",
                "comparator": "=",
                "customColor": {
                  "Default": "var(--dt-colors-charts-status-critical-default, #c62239)"
                },
                "field": "status_ready",
                "metadata": {
                  "applyTo": "cell",
                  "fields": [
                    "status_ready"
                  ]
                },
                "value": "false"
              }
            ]
          },
          "table": {
            "rowDensity": "comfortable"
          }
        },
        "querySettings": {
          "defaultSamplingRatio": 10,
          "defaultScanLimitGbytes": 500,
          "enableSampling": false,
          "maxResultMegaBytes": 1,
          "maxResultRecords": 1000
        },
        "davis": {
          "enabled": false,
          "davisVisualization": {
            "isAvailable": true
          }
        }
      },
      "2": {
        "title": "Policy Failure per Namespace",
        "type": "data",
        "query": "fetch security.events\n| filter event.type == \"COMPLIANCE_FINDING\" and event.provider==\"kyverno\"\n| fields timestamp,finding.severity,finding.title, finding.status, k8s.cluster.name, k8s.namespace.name, k8s.workload.name\n| filter finding.status !=\"pass\"\n| summarize count() , by:{k8s.namespace.name}",
        "visualization": "pieChart",
        "visualizationSettings": {
          "autoSelectVisualization": false,
          "chartSettings": {
            "legend": {
              "position": "right"
            }
          }
        },
        "querySettings": {
          "maxResultRecords": 1000,
          "defaultScanLimitGbytes": 500,
          "maxResultMegaBytes": 1,
          "defaultSamplingRatio": 10,
          "enableSampling": false
        },
        "davis": {
          "enabled": false,
          "davisVisualization": {
            "isAvailable": true
          }
        }
      },
      "3": {
        "title": "Failed Policy Results by Namespace",
        "type": "data",
        "subType": "dql-builder-metrics",
        "query": "timeseries { count(kyverno_policy_results), value.A = avg(kyverno_policy_results, scalar: true) }, by: { resource_namespace }, filter: { matchesValue(rule_result, \"fail\") }",
        "visualization": "honeycomb",
        "visualizationSettings": {
          "coloring": {
            "colorRules": [
              {
                "colorMode": "color-palette",
                "colorPalette": "red-inverted",
                "comparator": "= *value*",
                "field": "",
                "type": "string",
                "value": ""
              }
            ]
          },
          "honeycomb": {
            "labels": {
              "showLabels": true
            },
            "shape": "circle"
          }
        },
        "querySettings": {
          "defaultSamplingRatio": 10,
          "defaultScanLimitGbytes": 500,
          "enableSampling": false,
          "maxResultMegaBytes": 1,
          "maxResultRecords": 1000
        },
        "queryConfig": {
          "version": 20,
          "subQueries": [
            {
              "id": "A",
              "isEnabled": true,
              "datatype": "metrics",
              "metric": {
                "key": "kyverno_policy_results",
                "aggregation": "count"
              },
              "by": [
                "resource_namespace"
              ],
              "convertToValue": "Avg",
              "filter": "rule_result = fail "
            }
          ]
        },
        "davis": {
          "enabled": false,
          "davisVisualization": {
            "isAvailable": true
          }
        }
      },
