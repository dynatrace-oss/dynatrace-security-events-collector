      "16": {
        "title": "Kyverno Error Logs",
        "type": "data",
        "query": "fetch logs\n| filter k8s.namespace.name == \"kyverno\"\n| parse log, \"JSON:logjson\"\n| fieldsAdd kyverno_level=logjson[level], kyverno_kind=logjson[gvk], kyverno_resource=logjson[gvr], kyverno_resource_name=logjson[name],kyverno_resource_namespace=logjson[namespace],kyverno_resource_operation=logjson[operation],kyverno_error=logjson[error], kyverno_message=logjson[message], kyverno_looger=logjson[logger]\n| filter kyverno_level ==\"error\"\n| fields timestamp, k8s.deployment.name, kyverno_looger, kyverno_message, kyverno_kind, kyverno_resource, kyverno_resource_name , kyverno_resource_namespace , kyverno_resource_operation, kyverno_error",
        "visualization": "table",
        "visualizationSettings": {
          "autoSelectVisualization": true,
          "table": {
            "columnTypeOverrides": [
